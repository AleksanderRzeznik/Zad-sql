SELECT gatunki.gatunek, autorzy.imie FROM gatunki INNER JOIN autorzy ON gatunki.id_gatunku= autorzy.id_autora WHERE gatunek = 'Fantastyka' ORDER BY nazwisko DESC;
SELECT COUNT(tytul), id_autora FROM ksiazki GROUP BY id_autora;
SELECT COUNT(wypozyczenia.id_wypozyczenia), ksiazki.tytul ilosc_wypozyczonych_ksiazek FROM wypozyczenia INNER JOIN ksiazki ON wypozyczenia.id_ksiazki = ksiazki.id_ksiazki GROUP BY ksiazki.tytul;
SELECT COUNT(wypozyczenia.id_ksiazki), czytelnicy.imie, czytelnicy.nazwisko FROM wypozyczenia INNER JOIN czytelnicy ON wypozyczenia.id_czytelnika = czytelnicy.id_czytelnika GROUP BY czytelnicy.id_czytelnika;
SELECT COUNT(sprzedaz.ilosc), gatunki.gatunek FROM sprzedaz INNER JOIN gatunki ON sprzedaz.id_ksiazki = gatunki.id_gatunku GROUP BY gatunki.gatunek;
SELECT imie, nazwisko , wynagrodzenie FROM pracownicy GROUP BY id_pracownika HAVING wynagrodzenie > AVG(wynagrodzenie);
SELECT ksiazki.tytul, autorzy.imie FROM ksiazki INNER JOIN autorzy ON ksiazki.id_autora = autorzy.id_autora WHERE imie LIKE 'A%';
SELECT wypozyczenia.id_ksiazki, sprzedaz.id_czytelnika FROM wypozyczenia INNER JOIN sprzedaz ON wypozyczenia.id_ksiazki = sprzedaz.id_ksiazki GROUP BY id_czytelnika;
SELECT COUNT(pracownicy.id_stanowiska), stanowiska.nazwa FROM pracownicy INNER JOIN stanowiska ON pracownicy.id_stanowiska = stanowiska.id_stanowiska GROUP BY stanowiska.id_stanowiska ORDER BY COUNT(pracownicy.id_stanowiska) DESC;
SELECT miasto FROM czytelnicy GROUP BY miasto HAVING COUNT(miasto) <= 1;
SELECT tytul, cena_netto FROM ksiazki WHERE cena_netto > 40.00;
SELECT czytelnicy.imie, COUNT(wypozyczenia.id_wypozyczenia) FROM czytelnicy INNER JOIN wypozyczenia ON czytelnicy.id_czytelnika = wypozyczenia.id_czytelnika GROUP BY wypozyczenia.id_czytelnika ORDER BY COUNT(wypozyczenia.id_wypozyczenia) DESC;
SELECT imie, nazwisko FROM czytelnicy WHERE miasto = 'Poznan';
SELECT ksiazki.tytul, autorzy.imie, autorzy.nazwisko FROM ksiazki INNER JOIN autorzy ON ksiazki.id_autora = autorzy.id_autora WHERE autorzy.imie = 'Harlan';
